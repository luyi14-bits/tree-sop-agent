{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/main/schema.json",
  "productName": "Tree-SOP Agent",
  "version": "0.1.0",
  "identifier": "com.tree-sop.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "active": true,
    "targets": "all"
  },
  "app": {
    "windows": [
      {
        "title": "Tree-SOP Agent",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
